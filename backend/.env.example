# ============================================
# 漫画生成网站后端 - 环境变量配置示例
# ============================================
# 使用说明：
# 1. 复制本文件并重命名为 .env
# 2. 填入实际的配置值
# 3. .env 文件不会被提交到版本控制系统
# ============================================

# 服务器端口配置
PORT=3001

# OpenAI API 密钥 - 用于文字转漫画的 AI 生成功能
# 获取地址: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_key_here

# Stability AI API 密钥 - 用于图片风格迁移和漫画化处理
# 获取地址: https://platform.stability.ai/account/keys
STABILITY_API_KEY=your_key_here
